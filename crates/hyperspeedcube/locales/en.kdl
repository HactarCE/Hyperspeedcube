  (Tab)debug "Debug output" "Debug Output"
}

top_bar {
  desktop_link "Download desktop app"
  desktop_link_hover """
    The desktop version of Hyperspeedcube has the same features, but runs faster.
  """
  ui_layout_presets "UI layouts"
}

