leaderboards {
  sign_in "Leaderboards sign-in"
  sign_in_localhost "Leaderboards sign-in (localhost)"
  sign_in_desc """
    Hyperspeedcube is integrated with the
    [Hypercubing leaderboards]({{leaderboards_domain}}).

    If you sign in, you can automatically upload your
    fastest speedsolves and shortest solutions to the
    leaderboards.
  """
  sign_in_desc_localhost """
    This is a development build of Hyperspeedcube, so
    leaderboard integration requires running a local
    copy of the leaderboards.
  """

  actions {
    sign_in "Sign into the leaderboards"
    sign_in_using_browser "Sign in using browser"
    sign_out "Sign out"
  }

  loading {
    waiting_for_auth "Waiting for authentication ..."
    fetching_profile_info "Fetching profile info ..."
  }

  links {
    profile "My profile"
    submissions "My submissions"
    settings "Settings"
  }

  error_button "Error (click for details)"
  error_message "Error signing into leaderboards"
}

status_bar {
  filterless "This solve is eligible for the no-filters category."
  state {
    solved_from_full_scramble "Solved from a full scramble"
    fully_scrambled "Fully scrambled"
  }
  (HoverStrings)move_count {
    full "Move count"
    desc """
      Move count is measured using Slice Turn Metric.

      See [the Hypercubing wiki](https://hypercubing.xyz/notation/#turn-metrics) for more information.
    """
  }
  (HoverStrings)timer {
    full "Speedsolve timer"
    desc """
      **Inspection time** is measured from when the puzzle is first visible to the first twist.
      Inspection time above 60 seconds (displayed in red) may be penalized.
      The timer is yellow, orange, or red during inspection.

      **Solve time** is measured from the first move to when the puzzle is solved.

      Speedsolves must be completed in a single session.
    """
  }
  (HoverStrings)time {
    full "Speedsolve time"
    desc """
      Speedsolve time is measured from the first move to when the puzzle is solved.

      Speedsolves must be completed in a single session.
    """
  }
  (HoverStrings)blindsolve_time {
    full "Blindsolve time"
    desc """
      Blindsolve time is measured from when the puzzle is visible to when the blindfold is lifted.
    """
  }
  scramble {
    seed "Scramble seed"
    time "Scramble generation time"
  }
  cannot_view_solve_summary """
    The solve summary cannot be shown because the log file has been reloaded.
    You may still [submit to the leaderboards manually](https://lb.hypercubing.xyz/submit-solve).
  """
}

statuses {
  saved "Saved!"
  copied "Copied!"
  error "Error: {{error}}"
}

confirm_discard {
  title "Unsaved changes"

  exit "Discard puzzle state and exit?"
  close_tab "Discard puzzle state and close tab?"
  open_another_file "Discard puzzle state and open another file?"
  load_new_puzzle "Discard puzzle state and load new puzzle?"
  reset_puzzle "Discard puzzle state and reset puzzle?"
  scramble "Discard puzzle state and scramble?"
  update "Discord puzzle state and update the application?"
}

reset "Reset"
reset_to_value "Reset to {{value}}"

no_active_puzzle "No active puzzle"

cancel "Cancel"
try_again "Retry"

(HoverStrings)edit_as_plaintext {
  full "Edit as plaintext"
  desc "View and edit settings as plaintext to share them with others."
}

presets {
  save_changes "Save changes"
  create_current "Create {{current}}"
  overwrite_current "Overwrite {{current}}"
  add_named "Add {{name}}"
  reset_to_builtin "Reset to built-in values"

  // `default` is used as a fallback for others.
  (PresetStrings)default {
    saved_presets "Saved presets"
    current "{{current}} preset"
    current_empty "No preset"
    new_name_hint "New preset name"
    (PresetErrors)errors {
      empty_name "Preset name cannot be empty"
