lang "en"

tabs {
  puzzle_loading "Loading {{id}}"
  puzzle_error "Error loading {{id}}"

  (Tab)puzzle "New puzzle view" "No puzzle"
  (Tab)catalog "Catalog" "Catalog"
  (Tab)puzzle_info "Puzzle info" "Puzzle Info"
  (Tab)keybinds_reference "Keybinds reference" "Keybinds Reference"
  (Tab)about "About" "About"

  (Tab)colors "Colors" "Colors"
  (Tab)styles "Styles" "Styles"
  (Tab)view "View" "View"
  (Tab)animation "Animation" "Animation"

  (Tab)interaction "Interaction" "Interaction"
  (Tab)keybinds "Keybinds" "Keybinds"
