// - **Shape**
// - *Platonic*
// - Tetrahedron
// - Cube
// - Octahedron
// - Dodecahedron
// - Icosahedron
// - *Other*
// - Cuboid

layers_param = #{ name = "Layers", type = Int, default = 3, min = 1, max = 49 }


fn carve_polyhedron(shape: Map) {
    #puz.shape = shape
    #puz.colors = shape.id
    carve(shape.face_pole, shape.face_names)
}

fn cut_ft_polyhedron(shape: Map, cut_distances: List[Num]) {
    ax = add_axis(shape.face_pole, shape.face_names, cut_distances)
    // TODO: edge & vertex pseudo-axes
    add_axis_pair(ax, sym.thru(2).transform(ax))
}

add_menu_entry(path = "3D|Platonic|Cube|ET", priority = 51, id = "todo")
