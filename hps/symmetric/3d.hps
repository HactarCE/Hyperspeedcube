for id in ["megaminx", "curvy_starminx", "pentultimate"] {
    add_puzzle_generator(
        id = id,
        version = "0.1.0",
        engine = "euclid",
        ndim = 3,
        params = [layers_param],
        gen = fn(layers) {
            export fn build() {
                with #sym = cd([5,3]) {
                    carve(plane(#sym.oox))
                    ax = add_axis(#sym.oox)
                    // ax.add_twist()
                }
            }
        },
    )
}
for id in ["megaminx_crystal", "pyraminx_crystal", "starminx"] {
    add_puzzle(
        id = id,
        version = "0.1.0",
        engine = "euclid",
        ndim = 3,
        build = fn() {},
    )
}

add_menu_entry(
    path = "3D|Platonic|Cube|FT",
    priority = 52,
    default = true,
    id = "ft_cube",
    params = [layers_param],
    build = fn(layers) {
        carve_polyhedron(@shapes/bc/cube.new())
        // TODO: realistic proportions
        cut_ft_polyhedron(#puz.shape, @util/layers.inclusive(layers))
    }
)
