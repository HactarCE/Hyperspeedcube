add_menu_entry(
    path = "",
    next_column = "Space",
)

for ndim in 1..=7 {
    add_menu_entry(
        path = "${ndim}D",
        next_column = "Shape",
        build = fn() {
            export ndim
        },
    )
}

export fn add_menu_entry_for_shape(path: Str, priority: Int, shape: Map) {
    add_menu_entry(
        path = "${path}|${shape.name}",
        priority = priority,
        next_column = "Axes",
    )
    add_menu_entry(
        path = "${path}|${shape.name}|None",
        priority = 1000,
        id = shape.id,
        build = fn(*, shape = shape) { // capture `id`
            #puz.shape = shape.new()
            #puz.colors = #puz.shape.id
            element = ["vertex", "edge", "face"][#puz.ndim] ?? "facet"
            carve(shape["${element}_pole"], shape["${element}_names"])
        },
    )
}

add_menu_entry(path = "3D|Platonic", priority = 1000, section = true)
add_menu_entry_for_shape("3D|Platonic", -4, @shapes/3d/tetrahedron)
add_menu_entry_for_shape("3D|Platonic", -6, @shapes/3d/cube)
add_menu_entry_for_shape("3D|Platonic", -8, @shapes/3d/octahedron)
add_menu_entry_for_shape("3D|Platonic", -12, @shapes/3d/dodecahedron)
add_menu_entry_for_shape("3D|Platonic", -20, @shapes/3d/icosahedron)

